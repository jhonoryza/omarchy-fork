show_install_development_menu() {
  case $(menu "Install" "σΑΪè  Ruby on Rails\nοàü  Docker DB\nνû¹  JavaScript\nν‰ß  Go\nν€Ϋ  PHP\nν€Φ  Python\nν‰≠  Elixir\nνΘ·  Zig\nνû®  Rust\nν€Η  Java\nνùΩ  .NET\nνΓé  OCaml\nνù®  Clojure\nν€Ζ  Scala") in
